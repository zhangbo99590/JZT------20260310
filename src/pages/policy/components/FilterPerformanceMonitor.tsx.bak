/**
 * 筛选性能监控组件
 * 使用ECharts进行数据可视化展示
 */

import React, { useState, useEffect } from 'react';
import { Card, Row, Col, Statistic, Progress, Alert, Switch, Tooltip } from 'antd';
import { 
  ClockCircleOutlined, 
  DatabaseOutlined, 
  ThunderboltOutlined,
  WarningOutlined 
} from '@ant-design/icons';
import ReactECharts from 'echarts-for-react';
import { FilterPerformanceMetrics } from '../types/filterTypes';

interface FilterPerformanceMonitorProps {
  metrics: FilterPerformanceMetrics;
  isVisible?: boolean;
  onToggleVisibility?: (visible: boolean) => void;
}

const FilterPerformanceMonitor: React.FC<FilterPerformanceMonitorProps> = ({
  metrics,
  isVisible = false,
  onToggleVisibility
}) => {
  const [historicalData, setHistoricalData] = useState<Array<{
    timestamp: number;
    queryTime: number;
    cacheHitRate: number;
    errorRate: number;
  }>>([]);

  // 更新历史数据
  useEffect(() => {
    const newDataPoint = {
      timestamp: Date.now(),
      queryTime: metrics.queryTime,
      cacheHitRate: metrics.cacheHitRate * 100,
      errorRate: metrics.errorRate * 100
    };

    setHistoricalData(prev => {
      const updated = [...prev, newDataPoint];
      // 保留最近50个数据点
      return updated.slice(-50);
    });
  }, [metrics]);

  // 性能趋势图表配置
  const performanceTrendOption = {
    title: {
      text: '筛选性能趋势',
      left: 'center',
      textStyle: {
        fontSize: 14,
        fontWeight: 'normal'
      }
    },
    tooltip: {
      trigger: 'axis',
      axisPointer: {
        type: 'cross'
      },
      formatter: (params: any) => {
        const time = new Date(params[0].axisValue).toLocaleTimeString();
        let content = `时间: ${time}<br/>`;
        params.forEach((param: any) => {
          content += `${param.seriesName}: ${param.value.toFixed(2)}${param.seriesName.includes('时间') ? 'ms' : '%'}<br/>`;
        });
        return content;
      }
    },
    legend: {
      data: ['查询时间', '缓存命中率', '错误率'],
      bottom: 0
    },
    grid: {
      left: '3%',
      right: '4%',
      bottom: '15%',
      containLabel: true
    },
    xAxis: {
      type: 'category',
      boundaryGap: false,
      data: historicalData.map(d => d.timestamp),
      axisLabel: {
        formatter: (value: number) => new Date(value).toLocaleTimeString().slice(0, 5)
      }
    },
    yAxis: [
      {
        type: 'value',
        name: '时间 (ms)',
        position: 'left',
        axisLabel: {
          formatter: '{value} ms'
        }
      },
      {
        type: 'value',
        name: '百分比 (%)',
        position: 'right',
        axisLabel: {
          formatter: '{value}%'
        }
      }
    ],
    series: [
      {
        name: '查询时间',
        type: 'line',
        yAxisIndex: 0,
        data: historicalData.map(d => d.queryTime),
        smooth: true,
        lineStyle: {
          color: '#1890ff'
        },
        areaStyle: {
          color: {
            type: 'linear',
            x: 0,
            y: 0,
            x2: 0,
            y2: 1,
            colorStops: [
              { offset: 0, color: 'rgba(24, 144, 255, 0.3)' },
              { offset: 1, color: 'rgba(24, 144, 255, 0.1)' }
            ]
          }
        }
      },
      {
        name: '缓存命中率',
        type: 'line',
        yAxisIndex: 1,
        data: historicalData.map(d => d.cacheHitRate),
        smooth: true,
        lineStyle: {
          color: '#52c41a'
        }
      },
      {
        name: '错误率',
        type: 'line',
        yAxisIndex: 1,
        data: historicalData.map(d => d.errorRate),
        smooth: true,
        lineStyle: {
          color: '#ff4d4f'
        }
      }
    ]
  };

  // 性能分布饼图配置
  const performanceDistributionOption = {
    title: {
      text: '性能指标分布',
      left: 'center',
      textStyle: {
        fontSize: 14,
        fontWeight: 'normal'
      }
    },
    tooltip: {
      trigger: 'item',
      formatter: '{a} <br/>{b}: {c}ms ({d}%)'
    },
    legend: {
      orient: 'vertical',
      left: 'left',
      data: ['查询时间', '渲染时间', '其他处理时间']
    },
    series: [
      {
        name: '时间分布',
        type: 'pie',
        radius: '50%',
        center: ['50%', '60%'],
        data: [
          { value: metrics.queryTime, name: '查询时间' },
          { value: metrics.renderTime, name: '渲染时间' },
          { value: Math.max(0, 100 - metrics.queryTime - metrics.renderTime), name: '其他处理时间' }
        ],
        emphasis: {
          itemStyle: {
            shadowBlur: 10,
            shadowOffsetX: 0,
            shadowColor: 'rgba(0, 0, 0, 0.5)'
          }
        }
      }
    ]
  };

  // 获取性能等级
  const getPerformanceLevel = (queryTime: number) => {
    if (queryTime < 100) return { level: '优秀', color: '#52c41a' };
    if (queryTime < 300) return { level: '良好', color: '#faad14' };
    if (queryTime < 500) return { level: '一般', color: '#fa8c16' };
    return { level: '需优化', color: '#ff4d4f' };
  };

  const performanceLevel = getPerformanceLevel(metrics.queryTime);

  if (!isVisible) {
    return (
      <div className="fixed bottom-4 right-4 z-50">
        <Tooltip title="显示性能监控">
          <Card 
            size="small" 
            className="cursor-pointer shadow-lg hover:shadow-xl transition-shadow"
            onClick={() => onToggleVisibility?.(true)}
          >
            <div className="flex items-center gap-2">
              <ThunderboltOutlined className="text-blue-600" />
              <span className="text-sm">性能监控</span>
              <div 
                className="w-2 h-2 rounded-full"
                style={{ backgroundColor: performanceLevel.color }}
              />
            </div>
          </Card>
        </Tooltip>
      </div>
    );
  }

  return (
    <div className="fixed bottom-4 right-4 z-50 w-96">
      <Card
        title={
          <div className="flex items-center justify-between">
            <span className="flex items-center gap-2">
              <ThunderboltOutlined className="text-blue-600" />
              筛选性能监控
            </span>
            <Switch
              size="small"
              checked={isVisible}
              onChange={onToggleVisibility}
              checkedChildren="显示"
              unCheckedChildren="隐藏"
            />
          </div>
        }
        size="small"
        className="shadow-lg"
        bodyStyle={{ padding: '12px' }}
      >
        {/* 性能警告 */}
        {metrics.queryTime > 500 && (
          <Alert
            message="性能警告"
            description="查询时间过长，建议优化筛选条件"
            type="warning"
            icon={<WarningOutlined />}
            showIcon
            closable
            className="mb-3"
          />
        )}

        {/* 关键指标 */}
        <Row gutter={[8, 8]} className="mb-3">
          <Col span={12}>
            <Statistic
              title="查询时间"
              value={metrics.queryTime}
              suffix="ms"
              valueStyle={{ 
                color: performanceLevel.color,
                fontSize: '16px'
              }}
              prefix={<ClockCircleOutlined />}
            />
          </Col>
          <Col span={12}>
            <Statistic
              title="内存使用"
              value={metrics.memoryUsage}
              suffix="MB"
              valueStyle={{ fontSize: '16px' }}
              prefix={<DatabaseOutlined />}
            />
          </Col>
        </Row>

        {/* 进度条指标 */}
        <div className="mb-3">
          <div className="flex justify-between items-center mb-1">
            <span className="text-xs text-gray-600">缓存命中率</span>
            <span className="text-xs font-medium">{(metrics.cacheHitRate * 100).toFixed(1)}%</span>
          </div>
          <Progress
            percent={metrics.cacheHitRate * 100}
            size="small"
            strokeColor="#52c41a"
            showInfo={false}
          />
        </div>

        <div className="mb-3">
          <div className="flex justify-between items-center mb-1">
            <span className="text-xs text-gray-600">错误率</span>
            <span className="text-xs font-medium">{(metrics.errorRate * 100).toFixed(1)}%</span>
          </div>
          <Progress
            percent={metrics.errorRate * 100}
            size="small"
            strokeColor="#ff4d4f"
            showInfo={false}
          />
        </div>

        {/* 性能等级 */}
        <div className="mb-3 p-2 rounded" style={{ backgroundColor: `${performanceLevel.color}15` }}>
          <div className="flex items-center justify-between">
            <span className="text-sm font-medium">性能等级</span>
            <span 
              className="text-sm font-bold"
              style={{ color: performanceLevel.color }}
            >
              {performanceLevel.level}
            </span>
          </div>
        </div>

        {/* 性能趋势图表 */}
        {historicalData.length > 5 && (
          <div className="mb-3">
            <ReactECharts
              option={performanceTrendOption}
              style={{ height: '200px' }}
              opts={{ renderer: 'svg' }}
            />
          </div>
        )}

        {/* 性能分布图表 */}
        {(metrics.queryTime > 0 || metrics.renderTime > 0) && (
          <div>
            <ReactECharts
              option={performanceDistributionOption}
              style={{ height: '180px' }}
              opts={{ renderer: 'svg' }}
            />
          </div>
        )}

        {/* 优化建议 */}
        <div className="mt-3 p-2 bg-blue-50 rounded">
          <div className="text-xs text-blue-800 font-medium mb-1">优化建议</div>
          <div className="text-xs text-blue-600">
            {metrics.queryTime > 500 && '• 减少筛选条件数量\n'}
            {metrics.cacheHitRate < 0.5 && '• 优化缓存策略\n'}
            {metrics.errorRate > 0.1 && '• 检查数据格式\n'}
            {metrics.queryTime <= 500 && metrics.cacheHitRate >= 0.5 && metrics.errorRate <= 0.1 && '• 性能表现良好'}
          </div>
        </div>
      </Card>
    </div>
  );
};

export default FilterPerformanceMonitor;
